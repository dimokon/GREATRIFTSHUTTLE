<% const title='Browse Routes - Great Rift Shuttle' ; %>
    <%- include('dashboard-header') %>

        <div class="dashboard-wrapper">
            <%- include('dashboard-aside', { activePage: 'routes' }) %>

                <!-- Main Content -->
                <main class="dashboard-main">
                    <div class="dashboard-header">
                        <h1>Available Routes</h1>
                        <button id="openAddRouteModalBtn" class="btn btn-primary">Add New Route</button>
                    </div>

                    <dialog id="addRouteModal" class="dashboard-card modal-dialog">
                        <div class="modal-header">
                            <h2>Add Route</h2>
                            <button id="closeAddRouteModalBtn" class="close-btn">&times;</button>
                        </div>
                        <form action="/add-route" method="post">
                            <div class="group">
                                <label for="origin">Origin</label>
                                <input type="text" id="origin" name="origin" required>
                            </div>
                            <div class="group">
                                <label for="destination">Destination</label>
                                <input type="text" id="destination" name="destination" required>
                            </div>
                            <div class="group">
                                <label for="base_price">Base Price</label>
                                <input type="number" id="base_price" name="base_price" step="0.01" required>
                            </div>
                            <div class="group">
                                <label for="distance_km">Distance (km)</label>
                                <input type="number" id="distance_km" name="distance_km" step="0.01" required>
                            </div>
                            <div class="group">
                                <label for="estimated_duration">Estimated Duration (minutes)</label>
                                <input type="number" id="estimated_duration" name="estimated_duration" required>
                            </div>
                            <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 1rem;">Save Route</button>
                        </form>
                    </dialog>

                    <div class="dashboard-card">
                        <h2>Browse & Book Routes</h2>

                        <div class="card-controls">
                            <div class="search-box">
                                <input type="text" placeholder="Search routes by origin or destination..." />
                            </div>
                            <div class="filter-group">
                                <select>
                                    <option>All Routes</option>
                                    <option>Popular Routes</option>
                                    <option>Recently Added</option>
                                    <option>Best Price</option>
                                    <option>Shortest Duration</option>
                                </select>
                            </div>
                        </div>

                       
                    </div>
                    <div class="routes-list">

      <!-- origin, destination, base_price, distance_km, estimated_duration in a tables -->

        <table class="routes-table">
          <thead>
            <tr>
              <th>Origin</th>
              <th>Destination</th>
              <th>Base Price</th>
              <th>Distance (km)</th>
              <th>Estimated Duration (hours)</th>
            </tr>
          </thead>
          <tbody>
            <% routes.forEach(route => { %>
              <tr>
                <td><%= route.origin %></td>
                <td><%= route.destination %></td>
                <td>$<%= route.base_price %></td>
                <td><%= route.distance_km %> km</td>
                <td><%= route.estimated_duration %> hours</td>
              </tr>
            <% }) %>
          </tbody>
        </table>

      </div>

    
    </div>
                </main>
        </div>

        <script>
            const addRouteModal = document.getElementById('addRouteModal');
            const openAddRouteModalBtn = document.getElementById('openAddRouteModalBtn');
            const closeAddRouteModalBtn = document.getElementById('closeAddRouteModalBtn');

            openAddRouteModalBtn.addEventListener('click', () => {
                addRouteModal.showModal();
            });

            closeAddRouteModalBtn.addEventListener('click', () => {
                addRouteModal.close();
            });

            // Close when clicking outside
            addRouteModal.addEventListener('click', (e) => {
                const dialogDimensions = addRouteModal.getBoundingClientRect()
                if (
                    e.clientX < dialogDimensions.left ||
                    e.clientX > dialogDimensions.right ||
                    e.clientY < dialogDimensions.top ||
                    e.clientY > dialogDimensions.bottom
                ) {
                    addRouteModal.close()
                }
            });
        </script>

        <%- include('dashboard-footer') %>